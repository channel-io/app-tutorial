{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Google Calendar app server for Channel Talk App Store",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev": "node --env-file-if-exists=../../.env --import tsx src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@channel.io/app-sdk-core": "0.11.0",
    "@channel.io/app-sdk-server": "0.11.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "js-yaml": "^4.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
